{
  "version": "0.1.0",
  "nodeModulesDir": "auto",
  "tasks": {
    "test": "deno test --allow-all tests/"
  },
  "lint": {
    "include": ["elite.ts", "src/", "tests/"],
    "rules": {
      "tags": ["recommended"]
    }
  },
  "fmt": {
    "useTabs": true,
    "lineWidth": 160,
    "indentWidth": 4,
    "semiColons": false,
    "singleQuote": true,
    "proseWrap": "preserve",
    "include": ["elite.ts", "src/", "test/"]
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "@std/fmt": "jsr:@std/fmt@1",
    "@std/path": "jsr:@std/path@1",
    "@std/dotenv": "jsr:@std/dotenv@0",
    "@std/fs": "jsr:@std/fs@1",
    "@db/sqlite": "jsr:@db/sqlite@0.12",
    "@cliffy/command": "jsr:@cliffy/command@1",
    "onnxruntime-node": "npm:onnxruntime-node@1.18.0",
    "onnxruntime-web": "npm:onnxruntime-web@1.26.0",
    "essentia.js": "npm:essentia.js@0.1.3"
  }
}
